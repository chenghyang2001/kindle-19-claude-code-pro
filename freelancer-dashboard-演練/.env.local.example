# 環境變數範本（.env.local.example）
# 複製此檔為 .env.local 並填入真實值
# .env.local 已在 .gitignore 中排除，不會被 commit

# Neon Serverless PostgreSQL 連線字串
# 從 https://console.neon.tech/ 取得
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# NextAuth.js 密鑰（至少 32 字元隨機字串）
# 產生方式：openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# NextAuth.js 應用程式 URL
AUTH_URL=http://localhost:3000
